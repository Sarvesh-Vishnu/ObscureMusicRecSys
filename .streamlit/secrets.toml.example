# Copy to .streamlit/secrets.toml and fill in.
# secrets.toml is gitignored — never commit real credentials.

# Spotify is OPTIONAL — only used to render album art and "Open in Spotify" links.
# All recommendation logic runs without it.
[spotify]
client_id = ""
client_secret = ""

# Last.fm is OPTIONAL — improves tag enrichment during catalog ingestion.
[lastfm]
api_key = ""

# Ollama runs locally; override if you point at a remote host.
[ollama]
host = "http://localhost:11434"
model = "gemma3:4b"

# MusicBrainz requires a contact string per their API policy.
[musicbrainz]
app_name = "ObscureMusicRecSys"
app_version = "0.2.0"
contact = "you@example.com"
